rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------
    // Helper Functions (The Primitives)
    // -------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserRole() == role;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // -------------------------------------------------------------
    // Rules for Collections
    // -------------------------------------------------------------

    // Users: Profile read/write
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && 
                    // Prevent users from changing their own role after creation
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    // Goods: Any user can read, but specific roles can write
    match /goods/{goodId} {
      allow read: if isSignedIn();
      allow create: if hasRole('GUDANG') || hasRole('ADMIN') || hasRole('DONATUR');
      allow update: if isSignedIn() && (
        hasRole('GUDANG') || hasRole('ADMIN') || 
        (hasRole('RELAWAN') && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'qrcode', 'name', 'category', 'quantity', 'unit', 'warehouseId', 'donorId', 'donorName', 'createdAt', 'source', 'notes'
        ])) ||
        (hasRole('DONATUR') && request.auth.uid == resource.data.donorId && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'qrcode', 'volunteerId', 'volunteerName', 'warehouseId', 'status'
        ]))
      );
      allow delete: if hasRole('ADMIN');
    }

    // Donations: Public read, Donor write
    match /donations/{donationId} {
      allow read: if true;
      allow create: if isSignedIn(); // Donors create their own donation records
      allow update: if false; // Donations are immutable
      allow delete: if false;
    }

    // Fund Usage: Any user can read, but only Admin can write
    match /fundUsage/{usageId} {
      allow read: if true;
      allow create: if hasRole('ADMIN');
      allow update: if hasRole('ADMIN');
      allow delete: if hasRole('ADMIN');
    }

    // Logistics: Public read, Admin/Gudang write
    match /logistics/{logId} {
      allow read: if true;
      allow create, update, delete: if hasRole('ADMIN') || hasRole('GUDANG');
    }

    // Admin Ledger / Transactions: Admin only
    match /adminLedger/{id} {
      allow read, write: if hasRole('ADMIN');
    }
    match /transactions/{id} {
      allow read, write: if hasRole('ADMIN');
    }
    match /disasterFunds/{id} {
      allow read: if true;
      allow write: if hasRole('ADMIN');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
